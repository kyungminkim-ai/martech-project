# ──────────────────────────────────────────────────────
# 실제 데이터 / 개인정보 — 절대 커밋하지 않음
# ──────────────────────────────────────────────────────

# 입력 데이터 (비제스트 RAW, 브랜드 목록 등 운영 CSV)
**/input/*.csv
**/input/*.xlsx
**/input/*.json

# AD 코드 순번 시드는 예외 — 중복 발급 방지를 위해 추적 필요
!**/input/ad_code_seed.txt

# 출력 결과물 (캠페인메타엔진 CSV)
**/output/**
!**/output/.gitkeep

# 파이프라인 중간 파일
**/data/**
!**/data/.gitkeep

# 실행 로그
**/logs/**
!**/logs/.gitkeep

# ──────────────────────────────────────────────────────
# 환경 설정 / 시크릿
# ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ──────────────────────────────────────────────────────
# OS / IDE
# ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
